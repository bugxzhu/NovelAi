# 数据库路径（相对项目根目录，可选，默认 ./data/novelai.db）
NOVELAI_DB_PATH=./data/novelai.db

# 服务端口（可选，默认如下）
NOVELAI_HOST=127.0.0.1
NOVELAI_PORT=8000

# === LLM Provider 选择 ===
# 可选值：claude | openai
NOVELAI_LLM_PROVIDER=claude

# === Anthropic 兼容端点（NOVELAI_LLM_PROVIDER=claude 时使用）===
# 适用于 Anthropic 官方 / 代理 / Azure Claude 等
ANTHROPIC_API_KEY=
# 可选：自定义 base_url（如代理或自托管端点）；留空走官方
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BASE_URL=
# 模型名（所有任务共用同一模型）
ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI 兼容端点（NOVELAI_LLM_PROVIDER=openai 时使用）===
# 适用于 OpenAI 官方 / Azure OpenAI / 阿里 DashScope (Qwen) / Deepseek / Ollama / vLLM / LM Studio 等
# 示例（阿里 Qwen）:
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OPENAI_MODEL=qwen-plus
# 示例（Deepseek）:
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
# 示例（Ollama 本地）:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=qwen2.5:14b
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
