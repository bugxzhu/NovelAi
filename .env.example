# 数据库路径（相对项目根目录，可选，默认 ./data/novelai.db）
NOVELAI_DB_PATH=./data/novelai.db

# LLM Provider 配置（必填）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 服务端口（可选，默认如下）
NOVELAI_HOST=127.0.0.1
NOVELAI_PORT=8000

# LLM Provider 选择（claude 或 openai）
NOVELAI_DEFAULT_LLM_PROVIDER=claude

# OpenAI 兼容端点配置（适用于 OpenAI / DashScope / Ollama / vLLM 等）
# 示例：阿里 DashScope (Qwen)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

